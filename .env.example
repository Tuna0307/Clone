# =============================================================================
# LLM provider: "openai" or "bedrock"
# =============================================================================
LLM_PROVIDER=openai

# =============================================================================
# OpenAI credentials (required when LLM_PROVIDER=openai)
# =============================================================================
OPENAI_API_KEY=
OPENAI_API_BASE=
OPENAI_ORG_ID=

# =============================================================================
# AWS credentials (required only when LLM_PROVIDER=bedrock)
# =============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# =============================================================================
# Chat model configuration
# ---------------------------------------------------------------------------
# OpenAI example:   gpt-5.5
# Bedrock example:  us.meta.llama3-1-8b-instruct-v1:0
# =============================================================================
LLM_MODEL_ID=gpt-5.5
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=16384
OPENAI_REASONING_EFFORT=none

# =============================================================================
# Embedding model configuration
# ---------------------------------------------------------------------------
# OpenAI example:   text-embedding-3-small
# Bedrock example:  amazon.titan-embed-text-v2:0
# =============================================================================
EMBEDDING_MODEL_ID=text-embedding-3-small

# =============================================================================
# Optional provider endpoint override
# ---------------------------------------------------------------------------
# Leave empty for the provider default endpoint.
# For OpenAI-compatible gateways, this can point to the gateway base URL.
# For Bedrock, this can point to a custom AWS endpoint.
# =============================================================================
LLM_ENDPOINT_URL=
